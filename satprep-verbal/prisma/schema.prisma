// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Auth.js / NextAuth required models ──────────────────────────────────────

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?       @map("email_verified")
  image         String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  cspQuizSessions CspQuizSession[]

  @@map("user")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

// ── App models ───────────────────────────────────────────────────────────────

model Word {
  id             Int                 @id @default(autoincrement())
  word           String              @unique
  partOfSpeech   String              @map("part_of_speech")
  synonym        String
  sentence_1     String              @map("sentence")
  sentence_2     String?
  sentence_3     String?
  sentence_4     String?
  sentence_5     String?
  alphabetLetter String              @map("alphabet_letter")
  alphabetOrder  Int                 @map("alphabet_order")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  blankQuestions BlankSentenceQuestion[]
  progress       StudentProgress[]
  quizAnswers    QuizAnswer[]

  @@map("word")
}

model BlankSentenceQuestion {
  id              Int      @id @default(autoincrement())
  wordId          Int      @map("word_id")
  sentence        String
  blankSentence   String   @map("blank_sentence")
  sentence_2      String?
  blankSentence_2 String?
  sentence_3      String?
  blankSentence_3 String?
  sentence_4      String?
  blankSentence_4 String?
  sentence_5      String?
  blankSentence_5 String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  word            Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([wordId])
  @@map("blank_sentence_question")
}

model PassageSet {
  id          String           @id
  title       String?
  domain      String           @default("Unknown")
  skill       String           @default("Unknown")
  difficulty  String           @default("medium")
  sequence    Int?
  sourceWords String           @map("source_words")
  passage     String
  version     Int              @default(1)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  questions   PassageQuestion[]
  quizAnswers PassageQuizAnswer[]
  readStates  PassageReadState[]

  @@index([sequence])
  @@index([domain, skill])
  @@map("passage_set")
}

model PassageQuestion {
  id            Int            @id @default(autoincrement())
  passageSetId  String         @map("passage_set_id")
  questionId    String         @map("question_id")
  questionType  String         @map("question_type")
  questionText  String         @map("question_text")
  visualId      String?        @map("visual_id")
  choiceA       String         @map("choice_a")
  choiceB       String         @map("choice_b")
  choiceC       String         @map("choice_c")
  choiceD       String         @map("choice_d")
  correctAnswer String         @map("correct_answer")
  explanation   String
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  passageSet    PassageSet @relation(fields: [passageSetId], references: [id], onDelete: Cascade)
  visual        PassageVisual? @relation(fields: [visualId], references: [visualId], onDelete: SetNull)

  @@unique([passageSetId, questionId])
  @@index([visualId])
  @@map("passage_question")
}

model PassageVisual {
  visualId   String           @id @map("visual_id")
  type       String
  data       Json
  spec       Json
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  questions  PassageQuestion[]

  @@map("passage_visual")
}

model PassageImportLog {
  id        Int      @id @default(autoincrement())
  filename  String   @unique
  passageId String   @map("passage_id")
  checksum  String
  importedAt DateTime @default(now()) @map("imported_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([passageId])
  @@map("passage_import_log")
}

model PassageReadState {
  id           Int       @id @default(autoincrement())
  studentId    String    @map("student_id")
  passageSetId String    @map("passage_set_id")
  firstReadAt  DateTime  @default(now()) @map("first_read_at")

  passageSet   PassageSet @relation(fields: [passageSetId], references: [id], onDelete: Cascade)

  @@unique([studentId, passageSetId])
  @@index([studentId])
  @@map("passage_read_state")
}

model PassageQuizSession {
  id            Int                @id @default(autoincrement())
  studentId     String             @default("local-default-student") @map("student_id")
  quizNumber    Int                @map("quiz_number")
  quizName      String             @map("quiz_name")
  questionCount Int                @map("question_count")
  answeredCount Int                @default(0) @map("answered_count")
  correctCount  Int                @default(0) @map("correct_count")
  status        String             @default("in_progress")
  filterDomain  String?            @map("filter_domain")
  filterSkill   String?            @map("filter_skill")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  answers       PassageQuizAnswer[]

  @@index([studentId, quizNumber])
  @@map("passage_quiz_session")
}

model PassageQuizAnswer {
  id                   Int                @id @default(autoincrement())
  passageQuizSessionId Int                @map("passage_quiz_session_id")
  passageSetId         String             @map("passage_set_id")
  questionId           String             @map("question_id")
  domain               String
  skill                String
  selectedAnswer       String             @map("selected_answer")
  correctAnswer        String             @map("correct_answer")
  isCorrect            Boolean            @map("is_correct")
  createdAt            DateTime           @default(now()) @map("created_at")
  session              PassageQuizSession @relation(fields: [passageQuizSessionId], references: [id], onDelete: Cascade)
  passageSet           PassageSet         @relation(fields: [passageSetId], references: [id], onDelete: Cascade)

  @@unique([passageQuizSessionId, passageSetId])
  @@index([passageSetId])
  @@index([domain, skill])
  @@map("passage_quiz_answer")
}

model StudentPassageProgress {
  id           Int      @id @default(autoincrement())
  studentId    String   @map("student_id")
  domain       String
  skill        String
  attemptCount Int      @default(0) @map("attempt_count")
  correctCount Int      @default(0) @map("correct_count")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([studentId, domain, skill])
  @@index([studentId])
  @@map("student_passage_progress")
}

model StudentProgress {
  id           Int      @id @default(autoincrement())
  studentId    String   @default("local-default-student") @map("student_id")
  wordId       Int      @map("word_id")
  seenCount    Int      @default(0) @map("seen_count")
  correctCount Int      @default(0) @map("correct_count")
  lastResult   Boolean? @map("last_result")
  updatedAt    DateTime @updatedAt @map("updated_at")
  word         Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([studentId, wordId])
  @@map("student_progress")
}

model QuizSession {
  id             Int         @id @default(autoincrement())
  studentId      String      @default("local-default-student") @map("student_id")
  quizType       String      @map("quiz_type")
  quizNumber     Int         @map("quiz_number")
  quizName       String      @map("quiz_name")
  alphabetLetter String      @map("alphabet_letter")
  questionCount  Int         @map("question_count")
  answeredCount  Int         @default(0) @map("answered_count")
  correctCount   Int         @default(0) @map("correct_count")
  status        String      @default("in_progress")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  answers       QuizAnswer[]

  @@index([studentId, quizType, quizNumber])
  @@map("quiz_session")
}

model QuizAnswer {
  id            Int         @id @default(autoincrement())
  quizSessionId Int         @map("quiz_session_id")
  wordId        Int         @map("word_id")
  isCorrect     Boolean     @map("is_correct")
  createdAt     DateTime    @default(now()) @map("created_at")
  quizSession   QuizSession @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)
  word          Word        @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([quizSessionId, wordId])
  @@map("quiz_answer")
}

model CspQuestion {
  id                 String               @id
  unit               String
  stem               String
  choices            Json
  correctAnswerIndex Int                  @map("correct_answer_index")
  explanation        String
  difficulty         String?
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  attempts           CspQuestionAttempt[]

  @@index([unit])
  @@map("csp_question")
}

model CspQuizSession {
  id                Int                  @id @default(autoincrement())
  userId            String               @map("user_id")
  startedAt         DateTime             @default(now()) @map("started_at")
  completedAt       DateTime?            @map("completed_at")
  score             Int                  @default(0)
  totalQuestions    Int                  @map("total_questions")
  unitFilter        String?              @map("unit_filter")
  immediateFeedback Boolean              @default(true) @map("immediate_feedback")
  timeLimitSeconds  Int?                 @map("time_limit_seconds")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts          CspQuestionAttempt[]

  @@index([userId, startedAt])
  @@map("csp_quiz_session")
}

model CspQuestionAttempt {
  id             Int            @id @default(autoincrement())
  sessionId      Int            @map("session_id")
  questionId     String         @map("question_id")
  selectedAnswer Int            @map("selected_answer")
  isCorrect      Boolean        @map("is_correct")
  answeredAt     DateTime       @default(now()) @map("answered_at")
  session        CspQuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question       CspQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([questionId])
  @@map("csp_question_attempt")
}
